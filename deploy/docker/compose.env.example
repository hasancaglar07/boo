BOOK_WEB_ENV_FILE=/etc/book-generator/web.env
BOOK_DASHBOARD_ENV_FILE=/etc/book-generator/dashboard.env

BOOK_WEB_BIND_PORT=3000
BOOK_DASHBOARD_BIND_PORT=8765

BOOK_SQLITE_DIR=/var/www/book/runtime/sqlite

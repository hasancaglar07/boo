CODEFAST_API_KEY=sk-your-api-key
codefast=sk-your-api-key

# Text provider order (recommended: Claude primary + GLM fallback + Vertex fallback)
CODEFAST_TEXT_PROVIDER_ORDER="claude-main glm-main vertex-main"
CODEFAST_CLAUDE_BASE_URL="https://claudecode.codefast.app"
CODEFAST_GLM_BASE_URL="https://claudecode2.codefast.app"
BOOK_FULL_GENERATION_MAX_CONCURRENT=2
BOOK_PIPELINE_RECOVERY_ENABLED=1
# Capacity queue backoff to prevent retry storms under multi-book load.
BOOK_FULL_CAPACITY_RETRY_BASE_SECONDS=120
BOOK_FULL_CAPACITY_RETRY_JITTER_SECONDS=60
# Treat chapters as meaningful progress only after a substantial draft exists.
BOOK_MIN_CHAPTER_PROGRESS_WORDS=900
# Fast segment policy: single attempt per provider/model and quick failover.
BOOK_CHAPTER_SEGMENT_MAX_RETRIES=1
BOOK_CHAPTER_SEGMENT_FAST_FAILOVER=1
BOOK_CHAPTER_SEGMENT_PROVIDER_TIMEOUT_SECONDS=60
# If chapter extension keeps failing, allow bounded short-chapter acceptance to avoid infinite waiting loops.
BOOK_FULL_CHAPTER_EXTENSION_WAIT_BUDGET=3
BOOK_FULL_CHAPTER_SHORT_ACCEPT_ENABLED=1
BOOK_FULL_CHAPTER_SHORT_ACCEPT_MIN_PERCENT=45
BOOK_FULL_GENERATION_LENGTH_GRACE_PERCENT=95
BOOK_FULL_GENERATION_LENGTH_GRACE_WORDS=400
CODEFAST_CURL_MAX_TIME=60
SMART_API_RETRY_BASE_DELAY_SECONDS=1
CODEFAST_CLAUDE_TEXT_MODEL="claude-sonnet-4-6"
CODEFAST_CLAUDE_OUTLINE_MODEL="claude-sonnet-4-6"
CODEFAST_CLAUDE_CREATIVE_MODEL="claude-sonnet-4-6"
CODEFAST_CLAUDE_CHAPTER_SEGMENT_MODEL="claude-sonnet-4-6"
CODEFAST_CLAUDE_CHAPTER_EXTENSION_MODEL="claude-sonnet-4-6"
CODEFAST_TEXT_MODEL="GLM-5.1"
CODEFAST_TEXT_FALLBACK_MODEL="GLM-5-Turbo"
CODEFAST_CHAPTER_SEGMENT_MODEL="GLM-5.1"
CODEFAST_CHAPTER_SEGMENT_FALLBACK_MODEL="GLM-5-Turbo"
CODEFAST_CHAPTER_EXTENSION_MODEL="GLM-5.1"
CODEFAST_CHAPTER_EXTENSION_FALLBACK_MODEL="GLM-5-Turbo"

# Vertex text fallback configuration (books/chapters)
GOOGLE_API_KEY=
VERTEX_API_KEY=
GOOGLE_GENAI_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_PROJECT_ID=
VERTEX_PROJECT_ID=
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_LOCATION=us-central1
CODEFAST_VERTEX_TEXT_MODEL="gemini-2.5-flash-lite"
CODEFAST_VERTEX_TEXT_FALLBACK_MODEL="gemini-2.5-flash"
CODEFAST_VERTEX_CREATIVE_MODEL="gemini-2.5-flash-lite"
CODEFAST_VERTEX_CREATIVE_FALLBACK_MODEL="gemini-2.5-flash"
CODEFAST_VERTEX_OUTLINE_MODEL="gemini-2.5-flash-lite"
CODEFAST_VERTEX_OUTLINE_FALLBACK_MODEL="gemini-2.5-flash"
CODEFAST_VERTEX_CHAPTER_SEGMENT_MODEL="gemini-2.5-flash-lite"
CODEFAST_VERTEX_CHAPTER_SEGMENT_FALLBACK_MODEL="gemini-2.5-flash"
CODEFAST_VERTEX_CHAPTER_EXTENSION_MODEL="gemini-2.5-flash-lite"
CODEFAST_VERTEX_CHAPTER_EXTENSION_FALLBACK_MODEL="gemini-2.5-flash"
SHOWCASE_USE_OCR_FOR_AI_FRONT=0
BOOK_COVER_PROVIDER_CONNECT_TIMEOUT_SECONDS=10
BOOK_COVER_PROVIDER_READ_TIMEOUT_SECONDS=75
BOOK_PREVIEW_COVER_SERVICE=auto
BOOK_PREVIEW_COVER_TIMEOUT_SECONDS=180

# Keep local quota/exhausted gate disabled (recommended)
# Set to 1 only if you explicitly want local daily blocking behavior.
CODEFAST_ENABLE_LOCAL_LIMIT_TRACKING=0

# Cover/image fallback order used by scripts/generate_covers.sh
BOOK_COVER_PROVIDER_ORDER="grok-imagine nano-banana-pro nano-banana-2"

# Optional local fallback
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PREFERRED_MODEL=llama3.2:1b

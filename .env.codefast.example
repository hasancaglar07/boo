CODEFAST_API_KEY=sk-your-api-key
codefast=sk-your-api-key

# Text fallback order used by scripts/multi_provider_ai_simple.sh
CODEFAST_TEXT_PROVIDER_ORDER="codex-main glm-main api5-open claude-main api3-chat api13-premium gemini-main grok-main qwen-main ollama-local"

# Optional model overrides for newly added OpenAI-compatible endpoints
CODEFAST_API13_MODEL=claude-sonnet-4-5-20250929
CODEFAST_API5_MODEL=Qwen/Qwen2.5-72B-Instruct
CODEFAST_API3_MODEL=claude-4-5-sonnet

# Cover/image fallback order used by scripts/generate_covers.sh
BOOK_COVER_PROVIDER_ORDER="grok-imagine nano-banana-pro nano-banana-2"

# Optional local fallback
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PREFERRED_MODEL=llama3.2:1b
